# ── Digitally Agency — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values

# Grok AI (xAI) — https://console.x.ai
GROK_API_KEY=xai-your-key-here

# MongoDB — local or Atlas connection string
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/digitally
MONGO_URI=mongodb://localhost:27017

# OpenWeatherMap free API key — https://openweathermap.org/api
# Without this key, weather falls back to reasonable defaults
WEATHER_API_KEY=your-openweathermap-key-here

# Server port
PORT=5000
